    <string name="quiz_q1_q">¿Cuál es el nombre científico de la Avutarda?</string>
    <string-array name="quiz_q1_opts"><item>Otis tarda</item><item>Tetrax tetrax</item><item>Ciconia ciconia</item><item>Alectoris rufa</item></string-array>
    
    <string name="quiz_q2_q">La Avutarda es considerada una de las aves voladoras más pesadas del mundo. ¿En qué tipo de hábitat se encuentra principalmente?</string>
    <string-array name="quiz_q2_opts"><item>Bosques densos</item><item>Estepas cerealistas</item><item>Zonas costeras</item><item>Alta montaña</item></string-array>
    
    <string name="quiz_q3_q">¿A qué orden pertenece la Avutarda?</string>
    <string-array name="quiz_q3_opts"><item>Passeriformes</item><item>Otidiformes</item><item>Ciconiiformes</item><item>Falconiformes</item></string-array>
    
    <string name="quiz_q4_q">¿Cuál es el nombre científico de la Perdiz Roja?</string>
    <string-array name="quiz_q4_opts"><item>Perdix perdix</item><item>Alectoris rufa</item><item>Coturnix coturnix</item><item>Phasianus colchicus</item></string-array>
    
    <string name="quiz_q5_q">¿De qué se alimenta principalmente la Perdiz Roja?</string>
    <string-array name="quiz_q5_opts"><item>Peces pequeños</item><item>Insectos y pequeños mamíferos</item><item>Semillas, brotes y pequeños invertebrados</item><item>Exclusivamente de frutos</item></string-array>
    
    <string name="quiz_q6_q">¿Cuál es el nombre científico de la Cigüeña Blanca?</string>
    <string-array name="quiz_q6_opts"><item>Ciconia nigra</item><item>Ciconia ciconia</item><item>Mycteria ibis</item><item>Ardea cinerea</item></string-array>
    
    <string name="quiz_q7_q">La Cigüeña Blanca es considerada el animal más popular de la fauna silvestre de Pinto. ¿Dónde suele construir su nido?</string>
    <string-array name="quiz_q7_opts"><item>En madrigueras subterráneas</item><item>En tejados, torres y postes elevados</item><item>En arbustos a ras de suelo</item><item>En acantilados costeros</item></string-array>
    
    <string name="quiz_q8_q">¿A qué familia pertenece la Cigüeña Blanca?</string>
    <string-array name="quiz_q8_opts"><item>Ardeidae</item><item>Threskiornithidae</item><item>Ciconiidae</item><item>Accipitridae</item></string-array>
    
    <string name="quiz_q9_q">¿Cuál es el nombre científico del Sisón Común?</string>
    <string-array name="quiz_q9_opts"><item>Otis tarda</item><item>Tetrax tetrax</item><item>Burhinus oedicnemus</item><item>Pterocles orientalis</item></string-array>
    
    <string name="quiz_q10_q">El Sisón Común es un ave típica de las estepas de Pinto. ¿Qué característica tiene su vuelo?</string>
    <string-array name="quiz_q10_opts"><item>Planea durante horas sin batir las alas</item><item>Produce un silbido característico con las alas al volar</item><item>Solo vuela de noche</item><item>Vuela exclusivamente en formación en V</item></string-array>
    
    <string name="quiz_q11_q">¿Cuál es el nombre científico del Críalo?</string>
    <string-array name="quiz_q11_opts"><item>Cuculus canorus</item><item>Clamator glandarius</item><item>Upupa epops</item><item>Merops apiaster</item></string-array>
    
    <string name="quiz_q12_q">El Críalo tiene un comportamiento reproductivo muy peculiar. ¿Cuál es?</string>
    <string-array name="quiz_q12_opts"><item>Construye nidos colgantes muy elaborados</item><item>Es parásito de cría: pone sus huevos en nidos de otras aves</item><item>Incuba los huevos en la arena caliente</item><item>Ambos progenitores incuban por turnos de 24 horas</item></string-array>
    
    <string name="quiz_q13_q">¿Cuál es el nombre científico del Jilguero?</string>
    <string-array name="quiz_q13_opts"><item>Serinus serinus</item><item>Carduelis carduelis</item><item>Fringilla coelebs</item><item>Chloris chloris</item></string-array>
    
    <string name="quiz_q14_q">¿Por qué planta muestra especial preferencia el Jilguero para alimentarse?</string>
    <string-array name="quiz_q14_opts"><item>Roble</item><item>Cardo</item><item>Encina</item><item>Olivo</item></string-array>
    
    <string name="quiz_q15_q">¿Qué color característico tiene la cara del Jilguero?</string>
    <string-array name="quiz_q15_opts"><item>Azul intenso</item><item>Rojo, blanco y negro</item><item>Amarillo uniforme</item><item>Verde esmeralda</item></string-array>
    
    <string name="quiz_q16_q">¿Cuál es el nombre científico del Milano Real?</string>
    <string-array name="quiz_q16_opts"><item>Milvus migrans</item><item>Milvus milvus</item><item>Aquila chrysaetos</item><item>Circus aeruginosus</item></string-array>
    
    <string name="quiz_q17_q">¿Qué forma tiene la cola del Milano Real, que ayuda a identificarlo en vuelo?</string>
    <string-array name="quiz_q17_opts"><item>Redondeada</item><item>Cuadrada</item><item>Ahorquillada</item><item>Puntiaguda</item></string-array>
    
    <string name="quiz_q18_q">¿Cuál es el nombre científico del Aguilucho Pálido?</string>
    <string-array name="quiz_q18_opts"><item>Circus pygargus</item><item>Circus aeruginosus</item><item>Circus cyaneus</item><item>Accipiter gentilis</item></string-array>
    
    <string name="quiz_q19_q">¿Qué rasgo físico distingue fácilmente a la Avefría Europea?</string>
    <string-array name="quiz_q19_opts"><item>Un largo pico curvo</item><item>Una cresta o moño en la cabeza</item><item>Patas palmeadas de color rojo</item><item>Plumaje completamente blanco</item></string-array>
    
    <string name="quiz_q20_q">¿Cuál es el nombre científico del Busardo Ratonero?</string>
    <string-array name="quiz_q20_opts"><item>Buteo buteo</item><item>Falco peregrinus</item><item>Aquila pennata</item><item>Milvus migrans</item></string-array>
    
    <string name="quiz_q21_q">¿De qué se alimenta principalmente el Busardo Ratonero?</string>
    <string-array name="quiz_q21_opts"><item>Peces y anfibios</item><item>Frutos y semillas</item><item>Pequeños roedores</item><item>Insectos acuáticos</item></string-array>
    
    <string name="quiz_q22_q">¿Qué capacidad de vuelo es típica del Cernícalo Vulgar para localizar a sus presas?</string>
    <string-array name="quiz_q22_opts"><item>Vuela en espiral ascendente</item><item>Se cierne en el aire (vuelo estacionario)</item><item>Vuela rasante sobre el agua</item><item>Realiza picados a más de 300 km/h</item></string-array>
    
    <string name="quiz_q23_q">¿Cuál es el nombre científico del Mochuelo Europeo?</string>
    <string-array name="quiz_q23_opts"><item>Strix aluco</item><item>Tyto alba</item><item>Athene noctua</item><item>Bubo bubo</item></string-array>
    
    <string name="quiz_q24_q">¿En qué momento del día es más activo el Mochuelo Europeo?</string>
    <string-array name="quiz_q24_opts"><item>Exclusivamente de noche</item><item>Al amanecer y al atardecer (crepuscular)</item><item>Solo a mediodía</item><item>Únicamente durante tormentas</item></string-array>
    
    <string name="quiz_q25_q">¿Qué rasgo físico da nombre a la Cogujada Común?</string>
    <string-array name="quiz_q25_opts"><item>Su cola muy larga</item><item>Su cresta puntiaguda (cogujada)</item><item>Su pico curvo</item><item>Sus patas rojas</item></string-array>
    
    <string name="quiz_q26_q">¿Cuál es el nombre científico del Gorrión Común?</string>
