    <!-- InformacionActivity -->
    <string name="info_titulo">ABOUT THE APP</string>
    <string name="info_guia_aves_titulo">Bird Guide</string>
    <string name="info_guia_aves_desc">This application is a complete tool for ornithology lovers. It allows you to register and explore the wonderful world of birds interactively.</string>
    <string name="info_que_hacer_titulo">What can you do?</string>
    <string name="info_que_hacer_desc">• <b>Add new birds:</b> You can contribute by logging your own sightings.\n• <b>Edit Records:</b> Modify the details of any bird.\n• <b>Detailed Guide:</b> Check characteristics and audios of different birds.\n• <b>Mystery:</b> Solve our identification Quiz.\n• <b>Favorites:</b> Save the birds you like the most to keep them handy.\n• <b>Advanced Filters:</b> Find birds using the search bar or filtering by their size.</string>
    <string name="info_equipo_titulo">Development Team</string>
    <string name="info_equipo_desc">Created by:\n• Carla Arribas\n• German Narciso\n• Sergio López</string>
    <string name="info_entendido">UNDERSTOOD</string>

